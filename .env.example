# =============================================================================
# HEALTHCARE DEMO — Environment Variables
# Copy this file to .env and fill in all values before running setup.
# =============================================================================

# ---------------------------------------------------------------------------
# MongoDB Atlas — REQUIRED
# Get from Atlas UI: Connect > Drivers > copy the connection string
# ---------------------------------------------------------------------------
MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@YOUR-CLUSTER.mongodb.net/?retryWrites=true&w=majority&appName=healthcaredemo

# Database name (leave as-is unless you have a conflict)
DB_NAME=healthcare_demo

# ---------------------------------------------------------------------------
# Voyage AI — REQUIRED for embeddings
# Get from: https://dash.voyageai.com/api-keys
# ---------------------------------------------------------------------------
VOYAGE_API_KEY=pa-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ---------------------------------------------------------------------------
# Server configuration (defaults are fine for local demo)
# ---------------------------------------------------------------------------
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
FRONTEND_PORT=5173

# CORS — frontend origin; update if running on a different host
CORS_ORIGIN=http://localhost:5173
